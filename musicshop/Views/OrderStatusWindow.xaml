<Window x:Class="musicshop.OrderStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Изменить статус" SizeToContent="WidthAndHeight" MinWidth="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F0F4F2">
    <Grid Width="380">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Padding="20,14">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#B5D5CA" Offset="0"/>
                    <GradientStop Color="#FFFCD6" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.12" Direction="270"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <Border Background="#FFFFFF40" CornerRadius="6" Padding="7,4" Margin="0,0,12,0">
                    <TextBlock Text="📋" FontSize="18"/>
                </Border>
                <TextBlock Text="Изменить статус заказа" FontSize="15" FontWeight="Bold"
                           Foreground="#1A3A30" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
        <Border Grid.Row="1" Background="White" Padding="24,20">
            <Grid Width="332">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Номер заказа:" VerticalAlignment="Center" Margin="0,0,10,16" Foreground="#333"/>
                <Border Grid.Row="0" Grid.Column="1" Background="#FFFCD6" CornerRadius="6" Padding="10,6" Margin="0,0,0,16" HorizontalAlignment="Left">
                    <TextBlock x:Name="tbOrderId" FontSize="15" FontWeight="Bold" Foreground="#1A3A30"/>
                </Border>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Новый статус:" VerticalAlignment="Center" Margin="0,0,10,20" Foreground="#333"/>
                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="cmbStatus" Height="36" Margin="0,0,0,20" FontSize="13">
                    <ComboBoxItem Content="Новый"/>
                    <ComboBoxItem Content="В обработке"/>
                    <ComboBoxItem Content="Выполнен"/>
                    <ComboBoxItem Content="Отправлен"/>
                    <ComboBoxItem Content="Доставлен"/>
                    <ComboBoxItem Content="Отменён"/>
                </ComboBox>

                <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Отмена" Width="100" Height="36" Click="Cancel_Click" Style="{StaticResource DangerButton}" Margin="0,0,10,0"/>
                    <Button Content="Сохранить" Width="120" Height="36" Click="Save_Click" Style="{StaticResource SuccessButton}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>