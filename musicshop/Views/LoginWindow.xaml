<Window x:Class="musicshop.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация — Music Shop"
        SizeToContent="WidthAndHeight"
        MinWidth="500"
         MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#FFFCD6"
        ResizeMode="CanResize">
    <Grid Width="420">
        <Border Background="White" CornerRadius="10" Margin="30,30,30,30">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.12"/>
            </Border.Effect>
            <StackPanel Margin="40,32,40,32">

                <TextBlock Text="Music Shop" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="#000000" Margin="0,0,0,5"/>
                <TextBlock Text="Вход в систему" FontSize="13" Foreground="#888"
                           HorizontalAlignment="Center" Margin="0,0,0,26"/>

                <TextBlock Text="Логин" Foreground="#444" FontSize="13" Margin="0,0,0,5"/>
                <TextBox x:Name="txtLogin" Height="38" Margin="0,0,0,14"
                         VerticalContentAlignment="Center" Padding="10,0" FontSize="13"
                         BorderBrush="#BDBDBD" BorderThickness="1"/>

                <TextBlock Text="Пароль" Foreground="#444" FontSize="13" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtPassword" Height="38" Margin="0,0,0,22"
                             VerticalContentAlignment="Center" Padding="10,0" FontSize="13"
                             BorderBrush="#BDBDBD" BorderThickness="1"/>

                <Button Content="Войти" Height="42" FontSize="14" FontWeight="Bold"
                        Margin="0,0,0,10" Click="btnLogin_Click"/>

                <Button Content="Зарегистрироваться"
                        Height="38" FontSize="12"
                        Background="Transparent" Foreground="#000000"
                        BorderThickness="1" BorderBrush="#B5D5CA"
                        Click="btnRegister_Click"/>

                <TextBlock x:Name="txtStatus" Foreground="#8B0000" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,10,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
