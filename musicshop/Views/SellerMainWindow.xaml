<Window x:Class="musicshop.SellerMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Музыкальный магазин — Продавец" Height="760" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen" Background="#F0F4F2">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#B5D5CA" Offset="0"/>
                    <GradientStop Color="#D1EEFC" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15" Direction="270"/>
            </Border.Effect>
            <Grid Margin="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#B5D5CA" CornerRadius="8" Padding="8,4" Margin="0,0,12,0">
                        <TextBlock Text="♪" FontSize="22" Foreground="#4A8A7A" FontWeight="Bold"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Музыкальный магазин" Foreground="#1A3A30"
                                   FontSize="19" FontWeight="Bold"/>
                        <TextBlock Text="Панель продавца" Foreground="#4A7A6A" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border Background="#4CAF50" CornerRadius="8" Padding="10,5" Margin="0,0,10,0">
                        <TextBlock Text="ПРОДАВЕЦ" FontSize="12" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <Border Background="#FFFFFF40" CornerRadius="6" Padding="10,5" Margin="0,0,10,0">
                        <TextBlock x:Name="txtUserInfo" Foreground="#1A3A30" FontSize="13"/>
                    </Border>
                    <Button Content="Экспорт в Excel" Width="130" Height="32" Margin="0,0,10,0"
                            Background="#FFFCD6" Foreground="#000000" FontSize="12"
                            Click="ExportToExcel_Click"/>
                    <Button Content="Выйти" Width="80" Height="32"
                            Style="{StaticResource DangerButton}" Click="btnLogout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Вкладки -->
        <TabControl Grid.Row="1" Margin="10" Background="White"
                    BorderBrush="#B5D5CA" BorderThickness="1" x:Name="tabMain">

            <!-- ═══ АЛЬБОМЫ ═══ -->
            <TabItem Header="  Альбомы  ">
                <Grid Background="#F0F4F2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#FFFCD6" Padding="14,10"
                            BorderBrush="#B5D5CA" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            
                            <Border Background="White" CornerRadius="6" Padding="8,0"
                                    BorderBrush="#B5D5CA" BorderThickness="1.5" Height="34">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="🔍" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBox x:Name="txtSearchAlbum" Width="220" Height="28"
                                             BorderThickness="0" Padding="0" VerticalContentAlignment="Center"
                                             TextChanged="txtSearchAlbum_TextChanged"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10">
                        <WrapPanel x:Name="wrapAlbums" Orientation="Horizontal"/>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ═══ АРТИСТЫ ═══ -->
            <TabItem Header="  Артисты  ">
                <Grid Background="#F0F4F2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#FFFCD6" Padding="14,10"
                            BorderBrush="#B5D5CA" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                          
                            <Border Background="White" CornerRadius="6" Padding="8,0"
                                    BorderBrush="#B5D5CA" BorderThickness="1.5" Height="34">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="🔍" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBox x:Name="txtSearchArtist" Width="220" Height="28"
                                             BorderThickness="0" Padding="0" VerticalContentAlignment="Center"
                                             TextChanged="txtSearchArtist_TextChanged"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10">
                        <WrapPanel x:Name="wrapArtists" Orientation="Horizontal"/>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ═══ ГРУППЫ ═══ -->
            <TabItem Header="  Группы  ">
                <Grid Background="#F0F4F2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#FFFCD6" Padding="14,10"
                            BorderBrush="#B5D5CA" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            
                            <Border Background="White" CornerRadius="6" Padding="8,0"
                                    BorderBrush="#B5D5CA" BorderThickness="1.5" Height="34">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="🔍" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBox x:Name="txtSearchGroup" Width="220" Height="28"
                                             BorderThickness="0" Padding="0" VerticalContentAlignment="Center"
                                             TextChanged="txtSearchGroup_TextChanged"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10">
                        <WrapPanel x:Name="wrapGroups" Orientation="Horizontal"/>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ═══ ЗАКАЗЫ ═══ -->
            <TabItem Header="  Заказы  ">
                <Grid Background="#F0F4F2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#FFFCD6" Padding="14,10"
                            BorderBrush="#B5D5CA" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="+ Новый заказ" Width="140" Height="34" Margin="0,0,8,0"
                                    Style="{StaticResource SuccessButton}" Click="AddOrder_Click"/>
                            
                            <TextBlock Text="Статус:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox x:Name="cmbOrderStatus" Width="150" Height="34"
                                      SelectionChanged="cmbOrderStatus_SelectionChanged">
                                <ComboBoxItem Content="Все" IsSelected="True"/>
                                <ComboBoxItem Content="Новый"/>
                                <ComboBoxItem Content="В обработке"/>
                                <ComboBoxItem Content="Выполнен"/>
                                <ComboBoxItem Content="Отправлен"/>
                                <ComboBoxItem Content="Доставлен"/>
                                <ComboBoxItem Content="Отменён"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10">
                        <WrapPanel x:Name="wrapOrders" Orientation="Horizontal"/>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ═══ ОТЗЫВЫ ═══ -->
            <TabItem Header="  Отзывы  ">
                <Grid Background="#F0F4F2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#FFFCD6" Padding="14,10"
                            BorderBrush="#B5D5CA" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                           
                        </StackPanel>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10">
                        <WrapPanel x:Name="wrapFeedback" Orientation="Horizontal"/>
                    </ScrollViewer>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>