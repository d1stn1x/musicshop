<Window x:Class="musicshop.ArtistEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Артист" SizeToContent="WidthAndHeight" MinWidth="500"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize" Background="#F0F4F2">
    <Grid Width="520">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Padding="20,14">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#B5D5CA" Offset="0"/>
                    <GradientStop Color="#D1EEFC" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.12" Direction="270"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <Border Background="#FFFFFF40" CornerRadius="6" Padding="7,4" Margin="0,0,12,0">
                    <TextBlock Text="🎤" FontSize="18"/>
                </Border>
                <TextBlock x:Name="lblTitle" Text="Артист" FontSize="16" FontWeight="Bold"
                           Foreground="#1A3A30" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
        <Border Grid.Row="1" Background="White" Padding="24,20">
            <Grid Width="472">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="120"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Имя:" VerticalAlignment="Center" Margin="0,0,10,12" Foreground="#333"/>
                <TextBox   Grid.Row="0" Grid.Column="1" x:Name="txtName" Height="36" Margin="0,0,0,12" VerticalContentAlignment="Center" Padding="8,0" FontSize="13"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Фамилия:" VerticalAlignment="Center" Margin="0,0,10,12" Foreground="#333"/>
                <TextBox   Grid.Row="1" Grid.Column="1" x:Name="txtSurname" Height="36" Margin="0,0,0,12" VerticalContentAlignment="Center" Padding="8,0" FontSize="13"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Жанр:" VerticalAlignment="Center" Margin="0,0,10,12" Foreground="#333"/>
                <TextBox   Grid.Row="2" Grid.Column="1" x:Name="txtGenre" Height="36" Margin="0,0,0,12" VerticalContentAlignment="Center" Padding="8,0" FontSize="13"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Биография:" Margin="0,4,10,12" Foreground="#333"/>
                <TextBox   Grid.Row="3" Grid.Column="1" x:Name="txtBio" TextWrapping="Wrap" AcceptsReturn="True" Padding="8" Margin="0,0,0,12" FontSize="13"/>

                <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="Отмена" Width="100" Height="36" Click="Cancel_Click" Style="{StaticResource DangerButton}" Margin="0,0,10,0"/>
                    <Button Content="Сохранить" Width="120" Height="36" Click="Save_Click" Style="{StaticResource SuccessButton}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>