<Window x:Class="musicshop.ClientEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Клиент"
        SizeToContent="WidthAndHeight"
        MinWidth="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Width="450" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" x:Name="lblTitle"
                   Text="Добавить клиента" FontSize="16" FontWeight="Bold"
                   Foreground="#000000" Margin="0,0,0,16"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Имя:" VerticalAlignment="Center" Margin="0,0,10,12"/>
        <TextBox   Grid.Row="1" Grid.Column="1" x:Name="txtName" Height="36"
                   VerticalContentAlignment="Center" Padding="8,0" Margin="0,0,0,12"
                   BorderBrush="#B5D5CA" BorderThickness="1" FontSize="13"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Фамилия:" VerticalAlignment="Center" Margin="0,0,10,12"/>
        <TextBox   Grid.Row="2" Grid.Column="1" x:Name="txtSurname" Height="36"
                   VerticalContentAlignment="Center" Padding="8,0" Margin="0,0,0,12"
                   BorderBrush="#B5D5CA" BorderThickness="1" FontSize="13"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Телефон:" VerticalAlignment="Center" Margin="0,0,10,20"/>
        <TextBox   Grid.Row="3" Grid.Column="1" x:Name="txtPhone" Height="36"
                   VerticalContentAlignment="Center" Padding="8,0" Margin="0,0,0,20"
                   BorderBrush="#B5D5CA" BorderThickness="1" FontSize="13"/>

        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена" Width="100" Height="36" Click="Cancel_Click"
                    Background="#E0A9AF" Foreground="White" Margin="0,0,10,0"/>
            <Button Content="Сохранить" Width="110" Height="36" Click="Save_Click"
                    Style="{StaticResource SuccessButton}"/>
        </StackPanel>
    </Grid>
</Window>
