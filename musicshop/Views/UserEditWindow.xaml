<Window x:Class="musicshop.UserEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пользователь" SizeToContent="WidthAndHeight" MinWidth="520"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize" Background="#F0F4F2">
    <Grid Width="540">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Padding="20,14">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#E0A9AF" Offset="0"/>
                    <GradientStop Color="#FFFCD6" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.12" Direction="270"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <Border Background="#FFFFFF40" CornerRadius="6" Padding="7,4" Margin="0,0,12,0">
                    <TextBlock Text="👤" FontSize="18"/>
                </Border>
                <TextBlock x:Name="txtTitle" Text="Пользователь" FontSize="16" FontWeight="Bold"
                           Foreground="#1A0A0C" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
        <Border Grid.Row="1" Background="White" Padding="24,20">
            <Grid Width="492">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Логин *:" VerticalAlignment="Center" Margin="0,0,10,12" Foreground="#333"/>
                <TextBox   Grid.Row="0" Grid.Column="1" x:Name="txtLogin" Height="36" Margin="0,0,0,12" VerticalContentAlignment="Center" Padding="8,0" FontSize="13"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="ФИО:" VerticalAlignment="Center" Margin="0,0,10,12" Foreground="#333"/>
                <TextBox   Grid.Row="1" Grid.Column="1" x:Name="txtFullName" Height="36" Margin="0,0,0,12" VerticalContentAlignment="Center" Padding="8,0" FontSize="13"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Email:" VerticalAlignment="Center" Margin="0,0,10,12" Foreground="#333"/>
                <TextBox   Grid.Row="2" Grid.Column="1" x:Name="txtEmail" Height="36" Margin="0,0,0,12" VerticalContentAlignment="Center" Padding="8,0" FontSize="13"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Роль *:" VerticalAlignment="Center" Margin="0,0,10,12" Foreground="#333"/>
                <ComboBox  Grid.Row="3" Grid.Column="1" x:Name="cmbRole" Height="36" Margin="0,0,0,12" FontSize="13" VerticalContentAlignment="Center" Padding="6,0">
                    <ComboBoxItem Content="Клиент" IsSelected="True"/>
                    <ComboBoxItem Content="Продавец"/>
                    <ComboBoxItem Content="Администратор"/>
                </ComboBox>

                <TextBlock Grid.Row="4" Grid.Column="0" x:Name="lblPass" Text="Пароль *:" VerticalAlignment="Top" Margin="0,8,10,12" Foreground="#333"/>
                <StackPanel Grid.Row="4" Grid.Column="1" Margin="0,0,0,14">
                    <PasswordBox x:Name="txtPassword" Height="36" VerticalContentAlignment="Center" Padding="8,0" FontSize="13"/>
                    <TextBlock x:Name="lblPassHint" Text="(оставьте пустым, чтобы не менять)" FontSize="11" Foreground="#999" Margin="2,4,0,0" Visibility="Collapsed"/>
                </StackPanel>

                <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Margin="0,4,0,0">
                    <TextBlock x:Name="txtError" Foreground="#8B0000" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Отмена" Width="100" Height="36" Click="btnCancel_Click" Style="{StaticResource DangerButton}" Margin="0,0,10,0"/>
                        <Button Content="Сохранить" Width="120" Height="36" Click="btnSave_Click" Style="{StaticResource SuccessButton}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>