<Window x:Class="musicshop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Музыкальный магазин" Height="720" Width="1200"
        MinHeight="800" MinWidth="1200"
        WindowStartupLocation="CenterScreen" Background="#F0F4F2">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка с градиентом -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#B5D5CA" Offset="0"/>
                    <GradientStop Color="#D1EEFC" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15" Direction="270"/>
            </Border.Effect>
            <Grid Margin="20,0">
                <!-- Левая часть: ноты декор + название -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#B5D5CA" CornerRadius="8" Padding="8,4" Margin="0,0,12,0">
                        <TextBlock Text="♪" FontSize="22" Foreground="#4A8A7A" FontWeight="Bold"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Музыкальный магазин" Foreground="#1A3A30"
                                   FontSize="19" FontWeight="Bold"/>
                        <TextBlock x:Name="txtSubtitle" Text="Добро пожаловать"
                                   Foreground="#4A7A6A" FontSize="11"/>
                    </StackPanel>
                </StackPanel>

                <!-- Правая часть -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="Экспорт в Excel" Width="140" Height="32" Margin="0,0,12,0"
                            Background="#FFFCD6" FontSize="12" Click="ExportToExcel_Click"/>

                    <!-- Бейдж роли -->
                    <Border x:Name="roleBadge" CornerRadius="8" Padding="10,5" Margin="0,0,10,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.2"/>
                        </Border.Effect>
                        <TextBlock x:Name="txtRoleBadge" FontSize="12" FontWeight="Bold"/>
                    </Border>

                    <!-- Имя пользователя -->
                    <Border Background="#FFFFFF40" CornerRadius="6" Padding="10,5" Margin="0,0,10,0">
                        <TextBlock x:Name="txtUserInfo" Foreground="#1A3A30"
                                   FontSize="13" VerticalAlignment="Center"/>
                    </Border>

                    <Button Content="Выйти" Width="80" Height="32"
                            Style="{StaticResource DangerButton}"
                            Click="btnLogout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Вкладки -->
        <TabControl Grid.Row="1" Margin="10" Background="White" x:Name="tabMain"
                    BorderBrush="#B5D5CA" BorderThickness="1">

            <!-- ═══ АЛЬБОМЫ ═══ -->
            <TabItem Header="  Альбомы  ">
                <Grid Background="White">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#FFFCD6" Padding="12,10"
                            BorderBrush="#B5D5CA" BorderThickness="0,0,0,1">
                        <WrapPanel>
                            <Button Content="+ Добавить" Width="120" Height="34" Margin="0,0,8,0"
                                    x:Name="btnAddAlbum"
                                    Style="{StaticResource SuccessButton}" Click="AddAlbum_Click"/>
                            <Button Content="✎ Изменить" Width="120" Height="34" Margin="0,0,8,0"
                                    x:Name="btnEditAlbum" IsEnabled="False" Click="EditAlbum_Click"/>
                            <Button Content="✕ Удалить" Width="120" Height="34" Margin="0,0,8,0"
                                    Style="{StaticResource DangerButton}"
                                    x:Name="btnDeleteAlbum" IsEnabled="False" Click="DeleteAlbum_Click"/>
                            
                            <Border Background="White" CornerRadius="6" Padding="8,0"
                                    BorderBrush="#B5D5CA" BorderThickness="1.5" Height="34">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="🔍" FontSize="14" Margin="0,0,6,0"
                                               VerticalAlignment="Center"/>
                                    <TextBox x:Name="txtSearchAlbum" Width="170" Height="28"
                                             BorderThickness="0" Padding="0"
                                             VerticalContentAlignment="Center"
                                             TextChanged="txtSearchAlbum_TextChanged"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </Border>
                    <DataGrid x:Name="dgAlbums" Grid.Row="1" AutoGenerateColumns="False"
                              IsReadOnly="True" Margin="10" SelectionMode="Single"
                              SelectionChanged="dgAlbums_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"       Binding="{Binding ID_album}"        Width="55"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}"            Width="160"/>
                            <DataGridTextColumn Header="Год"      Binding="{Binding Year_of_release}" Width="60"/>
                            <DataGridTextColumn Header="Группа"   Binding="{Binding GroupName}"       Width="150"/>
                            <DataGridTextColumn Header="Описание" Binding="{Binding Description}"     Width="*"/>
                            <DataGridTextColumn Header="Цена"     Binding="{Binding PriceText}"       Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ═══ АРТИСТЫ ═══ -->
            <TabItem Header="  Артисты  ">
                <Grid Background="White">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#FFFCD6" Padding="12,10"
                            BorderBrush="#B5D5CA" BorderThickness="0,0,0,1">
                        <WrapPanel>
                            <Button Content="+ Добавить" Width="120" Height="34" Margin="0,0,8,0"
                                    x:Name="btnAddArtist"
                                    Style="{StaticResource SuccessButton}" Click="AddArtist_Click"/>
                            <Button Content="✎ Изменить" Width="120" Height="34" Margin="0,0,8,0"
                                    x:Name="btnEditArtist" IsEnabled="False" Click="EditArtist_Click"/>
                            <Button Content="✕ Удалить" Width="120" Height="34" Margin="0,0,8,0"
                                    Style="{StaticResource DangerButton}"
                                    x:Name="btnDeleteArtist" IsEnabled="False" Click="DeleteArtist_Click"/>
                            
                            <Border Background="White" CornerRadius="6" Padding="8,0"
                                    BorderBrush="#B5D5CA" BorderThickness="1.5" Height="34">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="🔍" FontSize="14" Margin="0,0,6,0"
                                               VerticalAlignment="Center"/>
                                    <TextBox x:Name="txtSearchArtist" Width="170" Height="28"
                                             BorderThickness="0" Padding="0"
                                             VerticalContentAlignment="Center"
                                             TextChanged="txtSearchArtist_TextChanged"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </Border>
                    <DataGrid x:Name="dgArtists" Grid.Row="1" AutoGenerateColumns="False"
                              IsReadOnly="True" Margin="10" SelectionMode="Single"
                              SelectionChanged="dgArtists_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"        Binding="{Binding ID_artist}"  Width="55"/>
                            <DataGridTextColumn Header="Имя"       Binding="{Binding Name}"       Width="150"/>
                            <DataGridTextColumn Header="Фамилия"   Binding="{Binding Surname}"    Width="150"/>
                            <DataGridTextColumn Header="Жанр"      Binding="{Binding Genre}"      Width="140"/>
                            <DataGridTextColumn Header="Биография" Binding="{Binding Biography}"  Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ═══ ГРУППЫ ═══ -->
            <TabItem Header="  Группы  ">
                <Grid Background="White">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#FFFCD6" Padding="12,10"
                            BorderBrush="#B5D5CA" BorderThickness="0,0,0,1">
                        <WrapPanel>
                            <Button Content="+ Добавить" Width="120" Height="34" Margin="0,0,8,0"
                                    x:Name="btnAddGroup"
                                    Style="{StaticResource SuccessButton}" Click="AddGroup_Click"/>
                            <Button Content="✎ Изменить" Width="120" Height="34" Margin="0,0,8,0"
                                    x:Name="btnEditGroup" IsEnabled="False" Click="EditGroup_Click"/>
                            <Button Content="✕ Удалить" Width="120" Height="34" Margin="0,0,8,0"
                                    Style="{StaticResource DangerButton}"
                                    x:Name="btnDeleteGroup" IsEnabled="False" Click="DeleteGroup_Click"/>
                            
                            <Border Background="White" CornerRadius="6" Padding="8,0"
                                    BorderBrush="#B5D5CA" BorderThickness="1.5" Height="34">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="🔍" FontSize="14" Margin="0,0,6,0"
                                               VerticalAlignment="Center"/>
                                    <TextBox x:Name="txtSearchGroup" Width="170" Height="28"
                                             BorderThickness="0" Padding="0"
                                             VerticalContentAlignment="Center"
                                             TextChanged="txtSearchGroup_TextChanged"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </Border>
                    <DataGrid x:Name="dgGroups" Grid.Row="1" AutoGenerateColumns="False"
                              IsReadOnly="True" Margin="10" SelectionMode="Single"
                              SelectionChanged="dgGroups_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"        Binding="{Binding ID_group}"  Width="55"/>
                            <DataGridTextColumn Header="Название"  Binding="{Binding Name}"      Width="140"/>
                            <DataGridTextColumn Header="Жанр"      Binding="{Binding Genre}"     Width="160"/>
                            <DataGridTextColumn Header="Биография" Binding="{Binding Biography}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ═══ ЗАКАЗЫ (Админ/Продавец) ═══ -->
            <TabItem Header="  Заказы  " x:Name="tabOrdersAdmin">
                <Grid Background="White">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#FFFCD6" Padding="12,10"
                            BorderBrush="#B5D5CA" BorderThickness="0,0,0,1">
                        <WrapPanel>
                            <Button Content="+ Новый заказ" Width="135" Height="34" Margin="0,0,8,0"
                                    x:Name="btnAddOrder"
                                    Style="{StaticResource SuccessButton}" Click="AddOrder_Click"/>
                            
                            <TextBlock Text="Статус:" VerticalAlignment="Center"
                                       Margin="0,0,6,0" FontSize="13"/>
                            <ComboBox x:Name="cmbOrderStatus" Width="155" Height="34"
                                      SelectionChanged="cmbOrderStatus_SelectionChanged">
                                <ComboBoxItem Content="Все" IsSelected="True"/>
                                <ComboBoxItem Content="Новый"/>
                                <ComboBoxItem Content="В обработке"/>
                                <ComboBoxItem Content="Выполнен"/>
                                <ComboBoxItem Content="Отправлен"/>
                                <ComboBoxItem Content="Доставлен"/>
                                <ComboBoxItem Content="Отменён"/>
                            </ComboBox>
                            <Button Content="✎ Изменить статус" Width="150" Height="34" Margin="8,0,0,0"
                                    x:Name="btnChangeStatus" IsEnabled="False"
                                    Click="ChangeOrderStatus_Click"/>
                        </WrapPanel>
                    </Border>
                    <DataGrid x:Name="dgOrders" Grid.Row="1" AutoGenerateColumns="False"
                              IsReadOnly="True" Margin="10" SelectionMode="Single"
                              SelectionChanged="dgOrders_SelectionChanged">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Height" Value="32"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Status_order}" Value="Новый">
                                        <Setter Property="Background" Value="#FFFCD6"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status_order}" Value="Отменён">
                                        <Setter Property="Background" Value="#F5D0D3"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status_order}" Value="В обработке">
                                        <Setter Property="Background" Value="#D1EEFC"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status_order}" Value="Выполнен">
                                        <Setter Property="Background" Value="#C8E8DF"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status_order}" Value="Отправлен">
                                        <Setter Property="Background" Value="#D1EEFC"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status_order}" Value="Доставлен">
                                        <Setter Property="Background" Value="#B5D5CA"/>
                                    </DataTrigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#A8D8F0"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#EAF6FF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="№"            Binding="{Binding ID_order}"      Width="55"/>
                            <DataGridTextColumn Header="Статус"       Binding="{Binding Status_order}"  Width="140"/>
                            <DataGridTextColumn Header="Дата"
                                    Binding="{Binding Date_of_execution, StringFormat=dd.MM.yyyy}"      Width="110"/>
                            <DataGridTextColumn Header="Пользователь" Binding="{Binding ClientName}"    Width="*"/>
                            <DataGridTextColumn Header="Сумма"
                                    Binding="{Binding TotalCost, StringFormat={}{0:N2} руб.}"           Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ═══ МОИ ЗАКАЗЫ (Клиент) ═══ -->
            <TabItem Header="  Мои заказы  " x:Name="tabOrdersClient">
                <Grid Background="White">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#FFFCD6" Padding="12,10"
                            BorderBrush="#B5D5CA" BorderThickness="0,0,0,1">
                        <WrapPanel>
                            <Button Content="♪ Купить альбом" Width="140" Height="34" Margin="0,0,8,0"
                                    Style="{StaticResource SuccessButton}" Click="BuyAlbum_Click"/>
                            <Button Content="✕ Отменить заказ" Width="145" Height="34" Margin="0,0,8,0"
                                    Style="{StaticResource DangerButton}"
                                    x:Name="btnCancelOrder" IsEnabled="False"
                                    Click="CancelOrder_Click"/>
                            
                        </WrapPanel>
                    </Border>
                    <DataGrid x:Name="dgOrdersClient" Grid.Row="1" AutoGenerateColumns="False"
                              IsReadOnly="True" Margin="10" SelectionMode="Single"
                              SelectionChanged="dgOrdersClient_SelectionChanged">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Height" Value="32"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Status_order}" Value="Новый">
                                        <Setter Property="Background" Value="#FFFCD6"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status_order}" Value="Отменён">
                                        <Setter Property="Background" Value="#F5D0D3"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status_order}" Value="В обработке">
                                        <Setter Property="Background" Value="#D1EEFC"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status_order}" Value="Выполнен">
                                        <Setter Property="Background" Value="#C8E8DF"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status_order}" Value="Доставлен">
                                        <Setter Property="Background" Value="#B5D5CA"/>
                                    </DataTrigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#A8D8F0"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#EAF6FF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="№"      Binding="{Binding ID_order}"      Width="55"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding Status_order}"  Width="160"/>
                            <DataGridTextColumn Header="Дата"
                                    Binding="{Binding Date_of_execution, StringFormat=dd.MM.yyyy}" Width="120"/>
                            <DataGridTextColumn Header="Альбом" Binding="{Binding AlbumName}"     Width="*"/>
                            <DataGridTextColumn Header="Сумма"
                                    Binding="{Binding TotalCost, StringFormat={}{0:N2} руб.}"     Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ═══ ОТЗЫВЫ ═══ -->
            <TabItem Header="  Отзывы  ">
                <Grid Background="White">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#FFFCD6" Padding="12,10"
                            BorderBrush="#B5D5CA" BorderThickness="0,0,0,1">
                        <WrapPanel>
                            <Button Content="+ Добавить" Width="120" Height="34" Margin="0,0,8,0"
                                    x:Name="btnAddFeedback"
                                    Style="{StaticResource SuccessButton}" Click="AddFeedback_Click"/>
                            <Button Content="✕ Удалить" Width="120" Height="34" Margin="0,0,8,0"
                                    Style="{StaticResource DangerButton}"
                                    x:Name="btnDeleteFeedback" IsEnabled="False"
                                    Click="DeleteFeedback_Click"/>
                            
                        </WrapPanel>
                    </Border>
                    <DataGrid x:Name="dgFeedback" Grid.Row="1" AutoGenerateColumns="False"
                              IsReadOnly="True" Margin="10" SelectionMode="Single"
                              SelectionChanged="dgFeedback_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"          Binding="{Binding ID_feedback}" Width="55"/>
                            <DataGridTextColumn Header="Пользователь" Binding="{Binding ClientName}" Width="200"/>
                            <DataGridTextColumn Header="Альбом"      Binding="{Binding AlbumName}"   Width="180"/>
                            <DataGridTextColumn Header="Оценка"      Binding="{Binding Rate}"        Width="80"/>
                            <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment}"     Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ═══ ПОЛЬЗОВАТЕЛИ (только Администратор) ═══ -->
            <TabItem Header="  Пользователи  " x:Name="tabUsers" Visibility="Collapsed">
                <Grid Background="White">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#F5D0D3" Padding="12,10"
                            BorderBrush="#E0A9AF" BorderThickness="0,0,0,2">
                        <WrapPanel>
                            <Border Background="#E0A9AF" CornerRadius="5" Padding="8,4" Margin="0,0,12,0">
                                <TextBlock Text="🔒 Только для администраторов" Foreground="#000000"
                                           FontWeight="Bold" VerticalAlignment="Center" FontSize="12"/>
                            </Border>
                            <Button Content="+ Добавить" Width="120" Height="34" Margin="0,0,8,0"
                                    Style="{StaticResource SuccessButton}" Click="AddUser_Click"/>
                            <Button Content="✎ Изменить" Width="120" Height="34" Margin="0,0,8,0"
                                    x:Name="btnEditUser" IsEnabled="False" Click="EditUser_Click"/>
                            <Button x:Name="btnToggleUser" Content="⊘ Заблокировать"
                                    Width="155" Height="34" Margin="0,0,8,0"
                                    Style="{StaticResource DangerButton}"
                                    IsEnabled="False" Click="ToggleUser_Click"/>
                            
                        </WrapPanel>
                    </Border>
                    <DataGrid x:Name="dgUsers" Grid.Row="1" AutoGenerateColumns="False"
                              IsReadOnly="True" Margin="10" SelectionMode="Single"
                              SelectionChanged="dgUsers_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"       Binding="{Binding UserID}"       Width="55"/>
                            <DataGridTextColumn Header="Логин"    Binding="{Binding Username}"     Width="140"/>
                            <DataGridTextColumn Header="ФИО"      Binding="{Binding FullName}"     Width="200"/>
                            <DataGridTextColumn Header="Роль"     Binding="{Binding Role}"         Width="130"/>
                            <DataGridTextColumn Header="Email"    Binding="{Binding Email}"        Width="180"/>
                            <DataGridTextColumn Header="Активен"  Binding="{Binding IsActiveText}" Width="80"/>
                            <DataGridTextColumn Header="Создан"
                                Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy}"             Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
