<Window x:Class="musicshop.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация — Music Shop"
        SizeToContent="WidthAndHeight"
        MinWidth="420"
        WindowStartupLocation="CenterScreen"
        Background="#FFFCD6"
        ResizeMode="CanResize">
    <Grid Width="440">
        <Border Background="White" CornerRadius="10" Margin="28,28,28,28">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.12"/>
            </Border.Effect>
            <StackPanel Margin="38,28,38,28">

                <TextBlock Text="Music Shop" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="#000000" Margin="0,0,0,4"/>
                <TextBlock Text="Создание аккаунта" FontSize="13" Foreground="#888"
                           HorizontalAlignment="Center" Margin="0,0,0,22"/>

                <TextBlock Text="Логин *" Foreground="#444" FontSize="13" Margin="0,0,0,5"/>
                <TextBox x:Name="txtLogin" Height="36" Margin="0,0,0,12"
                         VerticalContentAlignment="Center" Padding="8,0" FontSize="13"
                         BorderBrush="#BDBDBD" BorderThickness="1"/>

                <TextBlock Text="ФИО" Foreground="#444" FontSize="13" Margin="0,0,0,5"/>
                <TextBox x:Name="txtFullName" Height="36" Margin="0,0,0,12"
                         VerticalContentAlignment="Center" Padding="8,0" FontSize="13"
                         BorderBrush="#BDBDBD" BorderThickness="1"/>

                <TextBlock Text="Email" Foreground="#444" FontSize="13" Margin="0,0,0,5"/>
                <TextBox x:Name="txtEmail" Height="36" Margin="0,0,0,12"
                         VerticalContentAlignment="Center" Padding="8,0" FontSize="13"
                         BorderBrush="#BDBDBD" BorderThickness="1"/>

                <TextBlock Text="Роль *" Foreground="#444" FontSize="13" Margin="0,0,0,5"/>
                <ComboBox x:Name="cmbRole" Height="36" Margin="0,0,0,12" FontSize="13"
                          VerticalContentAlignment="Center" Padding="6,0">
                    <ComboBoxItem Content="Клиент" IsSelected="True"/>
                  
                </ComboBox>

                <StackPanel x:Name="pnlAdminCode" Visibility="Collapsed">
                    <TextBlock Text="Код администратора *" Foreground="#8B0000"
                               FontSize="13" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="txtAdminCode" Height="36" Margin="0,0,0,12"
                                 VerticalContentAlignment="Center" Padding="8,0" FontSize="13"
                                 BorderBrush="#E53935" BorderThickness="1"/>
                </StackPanel>

                <TextBlock Text="Пароль *" Foreground="#444" FontSize="13" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtPassword" Height="36" Margin="0,0,0,12"
                             VerticalContentAlignment="Center" Padding="8,0" FontSize="13"
                             BorderBrush="#BDBDBD" BorderThickness="1"/>

                <TextBlock Text="Повтор пароля *" Foreground="#444" FontSize="13" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtPasswordConfirm" Height="36" Margin="0,0,0,22"
                             VerticalContentAlignment="Center" Padding="8,0" FontSize="13"
                             BorderBrush="#BDBDBD" BorderThickness="1"/>

                <Button Content="Зарегистрироваться" Height="42" FontSize="14" FontWeight="Bold"
                        Style="{StaticResource SuccessButton}" Margin="0,0,0,10"
                        Click="btnRegister_Click"/>

                <Button Content="Уже есть аккаунт? Войти"
                        Height="38" FontSize="12"
                        Background="Transparent" Foreground="#000000"
                        BorderThickness="1" BorderBrush="#B5D5CA"
                        Click="btnGoLogin_Click"/>

                <TextBlock x:Name="txtStatus" Foreground="#8B0000" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,8,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
