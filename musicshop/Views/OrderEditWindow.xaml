<Window x:Class="musicshop.OrderEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новый заказ"
        SizeToContent="WidthAndHeight"
        MinWidth="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Width="450" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="110"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                   Text="Новый заказ" FontSize="16" FontWeight="Bold"
                   Foreground="#000000" Margin="0,0,0,16"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Клиент:" VerticalAlignment="Center" Margin="0,0,10,12"/>
        <ComboBox  Grid.Row="1" Grid.Column="1" x:Name="cmbClient" Height="36"
                   DisplayMemberPath="FullName" SelectedValuePath="ID_client"
                   Margin="0,0,0,12" FontSize="13"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Статус:" VerticalAlignment="Center" Margin="0,0,10,20"/>
        <ComboBox  Grid.Row="2" Grid.Column="1" x:Name="cmbStatus" Height="36"
                   Margin="0,0,0,20" FontSize="13">
            <ComboBoxItem Content="Новый" IsSelected="True"/>
            <ComboBoxItem Content="В обработке"/>
            <ComboBoxItem Content="Выполнен"/>
            <ComboBoxItem Content="Отменён"/>
        </ComboBox>

        <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена" Width="100" Height="36" Click="Cancel_Click"
                    Background="#E0A9AF" Foreground="White" Margin="0,0,10,0"/>
            <Button Content="Сохранить" Width="110" Height="36" Click="Save_Click"
                    Style="{StaticResource SuccessButton}"/>
        </StackPanel>
    </Grid>
</Window>
