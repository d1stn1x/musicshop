<Window x:Class="musicshop.BuyAlbumWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Купить альбом" SizeToContent="WidthAndHeight" MinWidth="500"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize" Background="#F0F4F2">
    <Grid Width="520">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Padding="20,14">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#D1EEFC" Offset="0"/>
                    <GradientStop Color="#B5D5CA" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.12" Direction="270"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <Border Background="#FFFFFF40" CornerRadius="6" Padding="7,4" Margin="0,0,12,0">
                    <TextBlock Text="♪" FontSize="18"/>
                </Border>
                <TextBlock Text="Купить альбом" FontSize="16" FontWeight="Bold"
                           Foreground="#1A3A30" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
        <Border Grid.Row="1" Background="White" Padding="24,20">
            <Grid Width="472">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Альбом:" VerticalAlignment="Center" Margin="0,0,10,12" Foreground="#333"/>
                <ComboBox  Grid.Row="0" Grid.Column="1" x:Name="cmbAlbum" Height="36" Margin="0,0,0,12" FontSize="13" SelectionChanged="cmbAlbum_SelectionChanged"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Цена:" VerticalAlignment="Center" Margin="0,0,10,12" Foreground="#333"/>
                <Border Grid.Row="1" Grid.Column="1" Background="#FFFCD6" CornerRadius="6" Padding="10,6" Margin="0,0,0,12" HorizontalAlignment="Left">
                    <TextBlock x:Name="txtPrice" Text="—" FontSize="15" FontWeight="Bold" Foreground="#1A3A30"/>
                </Border>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Описание:" VerticalAlignment="Top" Margin="0,4,10,16" Foreground="#333"/>
                <Border Grid.Row="2" Grid.Column="1" Background="#F0F4F2" CornerRadius="6" Padding="10,8" Margin="0,0,0,16">
                    <TextBlock x:Name="txtDesc" TextWrapping="Wrap" Foreground="#555" FontSize="12"/>
                </Border>

                <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Отмена" Width="100" Height="36" Click="Cancel_Click" Style="{StaticResource DangerButton}" Margin="0,0,10,0"/>
                    <Button Content="Купить" Width="120" Height="36" Click="Buy_Click" Style="{StaticResource SuccessButton}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>